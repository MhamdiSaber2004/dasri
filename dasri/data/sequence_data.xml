<odoo>
    <data noupdate="1">
        <record id="seq_dasri_contract" model="ir.sequence">
            <field name="name">Séquence Contrat DASRI</field>
            <field name="code">dasri.contract</field> <field name="prefix">CONT/%(year)s/</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_dasri_mission" model="ir.sequence">
            <field name="name">Séquence Mission DASRI</field>
            <field name="code">dasri.mission</field>
            <field name="prefix">MIS/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_dasri_bordereau" model="ir.sequence">
            <field name="name">Séquence Bordereau DASRI</field>
            <field name="code">dasri.bordereau</field>
            <field name="prefix">BOR/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_dasri_reception" model="ir.sequence">
            <field name="name">Séquence Réception DASRI</field>
            <field name="code">dasri.reception</field>
            <field name="prefix">REC/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_dasri_treatment" model="ir.sequence">
            <field name="name">Séquence Traitement DASRI</field>
            <field name="code">dasri.treatment</field>
            <field name="prefix">TRT/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
