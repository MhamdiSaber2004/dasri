<odoo>
    <record id="view_dasri_invoice_wizard_form" model="ir.ui.view">
        <field name="name">dasri.invoice.wizard.form</field>
        <field name="model">dasri.invoice.wizard</field>
        <field name="arch" type="xml">
            <form string="Facturation Mensuelle">
                <div class="oe_title">
                    <h1>Generer la facture mensuelle</h1>
                </div>
                <group>
                    <div class="o_form_label">
                        Choisissez le contrat, le mois et l'annee. La facture sera creee a partir des bordereaux valides de cette periode.
                    </div>
                </group>
                <group>
                    <field name="contract_id"/>
                    <field name="month"/>
                    <field name="year"/>
                </group>
                <footer>
                    <button name="action_generate_invoice" string="Generer" type="object" class="oe_highlight"/>
                    <button string="Annuler" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_dasri_invoice_wizard" model="ir.actions.act_window">
        <field name="name">Facturation Mensuelle</field>
        <field name="res_model">dasri.invoice.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
