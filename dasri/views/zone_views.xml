<odoo>
    <record id="view_dasri_zone_tree" model="ir.ui.view">
        <field name="name">dasri.zone.list</field>
        <field name="model">dasri.zone</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_dasri_zone_form" model="ir.ui.view">
        <field name="name">dasri.zone.form</field>
        <field name="model">dasri.zone</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                    <group string="Notes">
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dasri_zone" model="ir.actions.act_window">
        <field name="name">Zones DASRI</field>
        <field name="res_model">dasri.zone</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
